<div id="container">
    <div id="login" class="shadow-lg">
        <img src="img/logo.png">
        
        <form action="/dashboard" method="POST">
            <label class="mb-3 w-100">Login: <input type="text" name="login" class="form-control" required></label>
            <label class="mb-3 w-100">Senha: <input type="password" name="senha" class="form-control" required></label>

            <div class="text-center">
                <button type="submit" class="btn btn-secondary w-50">Entrar</button>
                {{#if messages.senhaIncorreta}}
                    <p class="mt-3 text-danger">{{messages.senhaIncorreta}}</p>
                 {{/if}}
            </div>
        </form>
    </div>
</div>